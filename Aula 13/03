        "# Operadores Aritiméticos\n",
        "\n",
        "\n",
        "1. \"+\"Soma\n",
        "2. \"-\"Subtração\n",
        "3. \"*\"Multiplicação\n",
        "4. \"/\"Divisão\n",
        "5. \"//\"Divisão inteira\n",
        "6. \"%\"Resto da divisão\n",
        "7. \"**\"Pontência\n",
        "\n",
        "#Operadores Relacionais\n",
        "1. \"==\" Igual\n",
        "2. \"!=\" Diferente\n",
        "3. \">\" Maior\n",
        "4. \"<\" Menor\n",
        "5. \">=\" Maior ou Igual\n",
        "6. \"<=\" Menor ou Igual\n",
        "\n",
