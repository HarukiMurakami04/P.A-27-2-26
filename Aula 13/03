        "#Calculadora simples\n",
        "#Entrada 2 Valores\n",
        "#Processamento calcular usando operados aritiméticos\n",
        "#Saída Mostrar Resultado\n",
        "\n",
        "#Entrada\n",
        "\n",
        "numero1 = int(input(\"digite um numero: \"))\n",
        "numero2 = int(input(\"digite o segundo numero: \"))\n",
        "\n",
        "#Processamento\n",
        "soma = numero1 + numero2\n",
        "subtração = numero1 - numero2\n",
        "multiplicação = numero1 * numero2\n",
        "divisão = numero1 / numero2\n",
        "div_inteira = numero1 // numero2\n",
        "resto = numero1 % numero2\n",
        "potência = numero1 ** numero2\n",
        "\n",
        "#Saída\n",
        "\n",
        "print(f\"O resultado da soma é :{soma}\")\n",
        "print(f\"O resultado da subtraçãode é igual: {subtração}\")\n",
        "print(f\"O resultado da multiplicação é igual: {multiplicação}\")\n",
        "print(f\"O resultado da divisão é igual: {divisão}\")\n",
        "print(f\"O resultado da divisão inteira é igual: {div_inteira}\")\n",
        "print(f\"O resto da divisão é igual: {resto}\")\n",
        "print(f\"O resultado da potência é igual: {potência}\")\n"
      ],
